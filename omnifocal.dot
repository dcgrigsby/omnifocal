        label="Skill Verification"

        verify_skill_structure [
            shape=parallelogram,
            failure_signature="skill_structure_errors",
            tool_command="sh scripts/validate-skill.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-skill.sh missing or failed — postmortem must write scripts/validate-skill.sh'; exit 1; }"
        ]
        check_skill_structure [shape=diamond, label="Skill Structure OK?"]

        verify_skill_e2e [
            shape=parallelogram,
            failure_signature="skill_e2e_errors",
            tool_command="sh scripts/validate-skill-e2e.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-skill-e2e.sh missing or failed — postmortem must write scripts/validate-skill-e2e.sh'; exit 1; }"
        ]
        check_skill_e2e [shape=diamond, label="Skill E2E OK?"]

        verify_fidelity_skill [
            shape=box,
            class="verify",
            failure_signature="skill_fidelity",
            prompt="Semantic acceptance-criteria review for the OmniFocal NanoClaw skill component.

Goal: $goal

Read:
- .ai/runs/$KILROY_RUN_ID/definition_of_done.md
- .ai/runs/$KILROY_RUN_ID/spec.md
- skills/omnifocal/SKILL.md
- .ai/runs/$KILROY_RUN_ID/test-evidence/latest/manifest.json (if present)

Verify each acceptance criterion by reading the actual skill file:

AC-5.1: skills/omnifocal/SKILL.md — verify file exists with valid YAML frontmatter containing name and description fields
AC-5.2: skills/omnifocal/SKILL.md — verify name field is lowercase, alphanumeric + hyphens, max 64 chars
AC-5.3: skills/omnifocal/SKILL.md — verify file is under 500 lines
AC-6.1: skills/omnifocal/SKILL.md — verify no mutating API patterns in code examples (new Task(, new Project(, .save(), markComplete(, remove, property assignment)
AC-6.2: skills/omnifocal/SKILL.md — verify explicit read-only enforcement instructions present
AC-7.1: skills/omnifocal/SKILL.md — verify query composition patterns for: inbox tasks, task search, project hierarchy, tags listing
AC-7.2: skills/omnifocal/SKILL.md — verify JSON.stringify instruction in examples
AC-7.3: skills/omnifocal/SKILL.md — verify POST /eval instruction present
AC-8.1: .ai/runs/$KILROY_RUN_ID/test-evidence/latest/IT-7/ — verify Claude Code CLI e2e evidence shows valid OmniFocus data returned

CRITICAL — DO NOT TRUST TOOL NODE RESULTS:
1. Read IT-6 and IT-7 evidence artifacts. If they are empty, missing, or contain only 'pass' with no supporting data, FAIL.
2. For IT-7, the evidence must show that Claude Code was actually invoked and produced output containing OmniFocus data. If the script just checked structure without running Claude Code, that is a FAIL for AC-8.1.

Cross-reference test evidence in manifest.json for IT-6 and IT-7 status.

Write results to .ai/runs/$KILROY_RUN_ID/verify_fidelity_skill.md.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):
On success: {\"status\":\"success\"}
On failure: {\"status\":\"fail\",\"failure_reason\":\"...\",\"failure_class\":\"deterministic_agent_bug\",\"failure_signature\":\"AC-X.Y,...\"} where the signature is a sorted comma-separated list of failing AC IDs"
        ]
        check_fidelity_skill [shape=diamond, label="Skill Fidelity OK?"]
    }

    // =========================================================================
    // Review
    // =========================================================================
    subgraph cluster_review {
        label="Review Fanout"
        node [shape=box]

        review_fanout [shape=component, label="Review Fan-Out"]

        review_a [class="branch-a", prompt="Review the OmniFocal implementation against its Definition of Done.

