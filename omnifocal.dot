            tool_command="command -v go >/dev/null 2>&1 && command -v osascript >/dev/null 2>&1 && command -v curl >/dev/null 2>&1 && command -v plutil >/dev/null 2>&1 && echo 'All tools available' || { echo 'KILROY_VALIDATE_FAILURE: missing required toolchain — need go, osascript, curl, plutil'; exit 1; }"
