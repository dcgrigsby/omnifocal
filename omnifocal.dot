        ]
    }

    // =========================================================================
    // Postmortem
    // =========================================================================
    subgraph cluster_postmortem {
        label="Postmortem"
        node [shape=box]

        postmortem [auto_status=true, prompt="Analyze failures and guide the next repair iteration for OmniFocal.

Goal: $goal

Read all available diagnostic sources:
- .ai/runs/$KILROY_RUN_ID/review_consensus.md (if review stage reached)
- .ai/runs/$KILROY_RUN_ID/verify_fidelity_server.md (if server semantic verify ran)
- .ai/runs/$KILROY_RUN_ID/verify_fidelity_skill.md (if skill semantic verify ran)
- .ai/runs/$KILROY_RUN_ID/implementation_log.md
- Branch review outputs via .ai/parallel_results.json + worktree_dir if available

Test evidence (required when present):
- If .ai/runs/$KILROY_RUN_ID/test-evidence/latest/manifest.json exists:
  * Read it first
  * For each failed or suspicious IT-* scenario, read listed artifacts that can materially improve diagnosis
  * Cite artifact file paths used as evidence in the postmortem
  * If an artifact is missing/unreadable/not produced, record that as a finding with the attempted path

Progress detection (required):
- Extract current failing AC IDs from verify_fidelity_server.md, verify_fidelity_skill.md, and review outputs
- Read context key last_failing_acs (written by previous postmortem iteration)
- If failing AC set is IDENTICAL to last_failing_acs → route needs_replan (zero progress; another impl_repair will not help)
- If failing AC set is smaller/different or this is first failure → route impl_repair
- Include context_updates in every status write: {\"context_updates\":{\"last_failing_acs\":\"AC-X.Y,AC-Z.W\"}} (sorted, comma-separated)

Output to .ai/runs/$KILROY_RUN_ID/postmortem_latest.md (overwrite previous):
- Root causes identified
- What worked (preserve — list specific files and functions)
- What failed (fix — list specific AC IDs and file paths)
- Concrete next changes (specific edits, not vague directions)
- Whether server, skill, or both need repair
- Must NOT direct from-scratch restart — preserve working code

Outcome classification:
- impl_repair: server code repair needed; plan/toolchain still valid (default on first failure with progress, when failing ACs are in AC-1 through AC-4)
- skill_repair: skill repair needed; server is fine but skill ACs failing (when failing ACs are in AC-5 through AC-8 only)
- needs_replan: plan/approach is inadequate; OR zero progress detected (identical failing ACs)
- needs_toolchain: environment/bootstrap/toolchain issue detected (missing tools, wrong versions)

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):
{\"status\":\"impl_repair\",\"context_updates\":{\"last_failing_acs\":\"AC-X.Y,...\"}}
or {\"status\":\"skill_repair\",\"context_updates\":{\"last_failing_acs\":\"AC-X.Y,...\"}}
or {\"status\":\"needs_replan\",\"context_updates\":{\"last_failing_acs\":\"AC-X.Y,...\"}}
or {\"status\":\"needs_toolchain\",\"failure_reason\":\"...\",\"context_updates\":{\"last_failing_acs\":\"AC-X.Y,...\"}}"]
    }

    // =========================================================================
    // Flow: Bootstrap
    // =========================================================================
    start -> check_toolchain
    check_toolchain -> expand_spec [condition="outcome=success"]
    check_toolchain -> check_toolchain [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_toolchain -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_toolchain -> postmortem
    expand_spec -> check_dod

    // DoD routing
    check_dod -> dod_fanout [condition="outcome=needs_dod"]
    check_dod -> plan_work [condition="outcome=has_dod"]
    check_dod -> dod_fanout

    // DoD fan-out
    dod_fanout -> dod_a
    dod_fanout -> dod_b
    dod_fanout -> dod_c
    dod_a -> consolidate_dod
    dod_b -> consolidate_dod
    dod_c -> consolidate_dod
    consolidate_dod -> plan_work

    // State detection after planning
    plan_work -> detect_state
    detect_state -> check_state

    // State routing
    check_state -> verify_fmt [condition="outcome=has_impl"]
    check_state -> implement_server [condition="outcome=needs_impl"]
    check_state -> implement_server

    // =========================================================================
    // Flow: Server Implementation
    // =========================================================================
    implement_server -> verify_fmt

    // =========================================================================
    // Flow: Server Verification
    // =========================================================================
    verify_fmt -> check_fmt
    check_fmt -> verify_build [condition="outcome=success"]
    check_fmt -> implement_server [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_fmt -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_fmt -> postmortem

    verify_build -> check_build
    check_build -> verify_test_server [condition="outcome=success"]
    check_build -> implement_server [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_build -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_build -> postmortem

    verify_test_server -> check_test_server
    check_test_server -> verify_fidelity_server [condition="outcome=success"]
    check_test_server -> implement_server [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_test_server -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_test_server -> postmortem

    verify_fidelity_server -> check_fidelity_server
    check_fidelity_server -> implement_skill [condition="outcome=success"]
    check_fidelity_server -> implement_server [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_fidelity_server -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_fidelity_server -> postmortem

    // =========================================================================
    // Flow: Skill Implementation
    // =========================================================================
    implement_skill -> verify_skill_structure

    // =========================================================================
    // Flow: Skill Verification
    // =========================================================================
    verify_skill_structure -> check_skill_structure
    check_skill_structure -> verify_skill_e2e [condition="outcome=success"]
    check_skill_structure -> implement_skill [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_skill_structure -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_skill_structure -> postmortem

    verify_skill_e2e -> check_skill_e2e
    check_skill_e2e -> verify_fidelity_skill [condition="outcome=success"]
    check_skill_e2e -> implement_skill [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_skill_e2e -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_skill_e2e -> postmortem

    verify_fidelity_skill -> check_fidelity_skill
    check_fidelity_skill -> review_fanout [condition="outcome=success"]
    check_fidelity_skill -> implement_skill [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_fidelity_skill -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_fidelity_skill -> postmortem

    // =========================================================================
    // Flow: Review
    // =========================================================================
    review_fanout -> review_a
    review_fanout -> review_b
    review_fanout -> review_c
    review_a -> review_consensus
    review_b -> review_consensus
    review_c -> review_consensus

    // Consensus routing
    review_consensus -> exit [condition="outcome=success"]
    review_consensus -> postmortem [condition="outcome=rejected"]
    review_consensus -> postmortem

    // =========================================================================
    // Flow: Postmortem recovery routing
    // =========================================================================
    // Transient infra — restart from toolchain check
    postmortem -> check_toolchain [condition="outcome=fail && context.failure_class=transient_infra"]
    // Server code repair — server ACs failing
    postmortem -> repair_server [condition="outcome=impl_repair"]
    // Skill repair — skill ACs failing, server is fine
    postmortem -> repair_skill [condition="outcome=skill_repair"]
    // Replan — approach is inadequate or zero progress
    postmortem -> plan_work [condition="outcome=needs_replan"]
    // Toolchain issue — re-check environment
    postmortem -> check_toolchain [condition="outcome=needs_toolchain"]
    // Unconditional fallback (must be last)
    postmortem -> repair_server

    // =========================================================================
    // Flow: Repair back to verification
    // =========================================================================
    repair_server -> verify_fmt
    repair_skill -> verify_skill_structure
}
