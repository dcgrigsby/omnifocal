<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.omnifocal.server</string>

	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/omnifocal-server</string>
		<string>--i-accept-the-risk</string>
	</array>

	<key>KeepAlive</key>
	<true/>

	<key>RunAtLoad</key>
	<true/>

	<key>StandardOutPath</key>
	<string>/tmp/omnifocal-server.stdout.log</string>

	<key>StandardErrorPath</key>
	<string>/tmp/omnifocal-server.stderr.log</string>
</dict>
</plist>
